{
	"name": "df_transform_ecdc_hospital_admission",
	"properties": {
		"folder": {
			"name": "covid19"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_source_ecdc_hospital_adls_gen2",
						"type": "DatasetReference"
					},
					"name": "sourceHospitalAdmission"
				},
				{
					"dataset": {
						"referenceName": "ds_source_ecdc_country_lookup",
						"type": "DatasetReference"
					},
					"name": "sourceCountryLookupFile"
				},
				{
					"dataset": {
						"referenceName": "ds_source_ecdc_date_lookup",
						"type": "DatasetReference"
					},
					"name": "sourceDateLookup"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_sink_ecdc_hospital_daily_adls_gen2",
						"type": "DatasetReference"
					},
					"name": "sinkDailyHospital"
				},
				{
					"dataset": {
						"referenceName": "ds_sink_ecdc_hospital_weekly_adls_gen2",
						"type": "DatasetReference"
					},
					"name": "sinkWeeklyHospital"
				}
			],
			"transformations": [
				{
					"name": "joinHospitalAndCountryLookup"
				},
				{
					"name": "deriveWeekJoinKey"
				},
				{
					"name": "splitDailyWeekly"
				},
				{
					"name": "selectRequiredFields"
				},
				{
					"name": "deriveDatePopulationAndValue"
				},
				{
					"name": "selectDailyRequiredFields"
				},
				{
					"name": "pivotDailyDetails"
				},
				{
					"name": "selectRenameDailyFields"
				},
				{
					"name": "derivedNullValues"
				},
				{
					"name": "selectWeeklyRequiredFields"
				},
				{
					"name": "pivotWeeklyDetails"
				},
				{
					"name": "lookupDateDimension"
				},
				{
					"name": "aggWeekBeginEnd"
				},
				{
					"name": "selectDateRequiredFields"
				},
				{
					"name": "derivedValueColumns"
				},
				{
					"name": "selectRenameWeeklyFields"
				},
				{
					"name": "derivedWeeklyNullValues"
				}
			],
			"scriptLines": [
				"source(output(",
				"          country as string,",
				"          indicator as string,",
				"          date as string,",
				"          year_week as string,",
				"          value as string,",
				"          source as string,",
				"          url as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceHospitalAdmission",
				"source(output(",
				"          country as string,",
				"          country_code_2_digit as string,",
				"          country_code_3_digit as string,",
				"          continent as string,",
				"          population as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceCountryLookupFile",
				"source(output(",
				"          date_key as string,",
				"          date as string,",
				"          year as string,",
				"          month as string,",
				"          day as string,",
				"          day_name as string,",
				"          day_of_year as string,",
				"          week_of_month as string,",
				"          week_of_year as string,",
				"          month_name as string,",
				"          year_month as string,",
				"          year_week as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> sourceDateLookup",
				"sourceHospitalAdmission, sourceCountryLookupFile join(sourceHospitalAdmission@country == sourceCountryLookupFile@country,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'right')~> joinHospitalAndCountryLookup",
				"selectDateRequiredFields derive(year_week_key = year + '-W' + lpad(week_of_year, 2, '0'),",
				"          date = toDate(date, 'yyyy-MM-dd')) ~> deriveWeekJoinKey",
				"selectRequiredFields split(equals(substring(indicator, 1, 5), 'Daily'),",
				"     disjoint: false) ~> splitDailyWeekly@(DailyData, WeeklyData)",
				"joinHospitalAndCountryLookup select(mapColumn(",
				"          country = sourceHospitalAdmission@country,",
				"          country_code_2_digit,",
				"          country_code_3_digit,",
				"          population,",
				"          date,",
				"          year_week,",
				"          indicator,",
				"          value,",
				"          source",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRequiredFields",
				"splitDailyWeekly@DailyData derive(reported_date = toDate(date, 'yyyy-MM-dd'),",
				"          population = toLong(population),",
				"          value = toLong(value)) ~> deriveDatePopulationAndValue",
				"deriveDatePopulationAndValue select(mapColumn(",
				"          country,",
				"          country_code_2_digit,",
				"          country_code_3_digit,",
				"          population,",
				"          reported_date,",
				"          indicator,",
				"          value,",
				"          source",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectDailyRequiredFields",
				"selectDailyRequiredFields pivot(groupBy(country,",
				"          country_code_2_digit,",
				"          country_code_3_digit,",
				"          population,",
				"          reported_date,",
				"          source),",
				"     pivotBy(indicator, ['Daily hospital occupancy', 'Daily ICU occupancy']),",
				"     count = sum(coalesce(value, 0)),",
				"     columnNaming: '$V_$N',",
				"     lateral: false) ~> pivotDailyDetails",
				"pivotDailyDetails select(mapColumn(",
				"          country,",
				"          country_code_2_digit,",
				"          country_code_3_digit,",
				"          population,",
				"          reported_date,",
				"          hospital_occupancy_count = {Daily hospital occupancy_count},",
				"          icu_occupancy_count = {Daily ICU occupancy_count},",
				"          source",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameDailyFields",
				"selectRenameDailyFields derive(hospital_occupancy_count = coalesce(hospital_occupancy_count, 0),",
				"          icu_occupancy_count = coalesce(icu_occupancy_count, 0)) ~> derivedNullValues",
				"lookupDateDimension select(mapColumn(",
				"          country,",
				"          country_code_2_digit,",
				"          country_code_3_digit,",
				"          population,",
				"          reported_year_week = year_week,",
				"          reported_week_start_date,",
				"          reported_week_end_date,",
				"          indicator,",
				"          value,",
				"          source",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectWeeklyRequiredFields",
				"derivedValueColumns pivot(groupBy(country,",
				"          country_code_2_digit,",
				"          country_code_3_digit,",
				"          population,",
				"          reported_year_week,",
				"          source,",
				"          reported_week_start_date,",
				"          reported_week_end_date),",
				"     pivotBy(indicator, ['Weekly new hospital admissions per 100k', 'Weekly new ICU admissions per 100k']),",
				"     count = sum(value),",
				"     columnNaming: '$V_$N',",
				"     lateral: false) ~> pivotWeeklyDetails",
				"splitDailyWeekly@WeeklyData, aggWeekBeginEnd lookup(year_week == year_week_key,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'right')~> lookupDateDimension",
				"deriveWeekJoinKey aggregate(groupBy(year,",
				"          week_of_year,",
				"          year_week_key),",
				"     reported_week_start_date = min(date),",
				"          reported_week_end_date = max(date)) ~> aggWeekBeginEnd",
				"sourceDateLookup select(mapColumn(",
				"          date,",
				"          year,",
				"          week_of_year",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectDateRequiredFields",
				"selectWeeklyRequiredFields derive(value = coalesce(toDecimal(value, 17, 2), 0.00)) ~> derivedValueColumns",
				"pivotWeeklyDetails select(mapColumn(",
				"          country,",
				"          country_code_2_digit,",
				"          country_code_3_digit,",
				"          population,",
				"          reported_year_week,",
				"          reported_week_start_date,",
				"          reported_week_end_date,",
				"          hospital_occupancy_count = {Weekly new hospital admissions per 100k_count},",
				"          icu_occupancy_count = {Weekly new ICU admissions per 100k_count},",
				"          source",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameWeeklyFields",
				"selectRenameWeeklyFields derive(population = toLong(population),",
				"          hospital_occupancy_count = coalesce(hospital_occupancy_count, 0.00),",
				"          icu_occupancy_count = coalesce(icu_occupancy_count, 0.00)) ~> derivedWeeklyNullValues",
				"derivedNullValues sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0777,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     dateFormat:'yyyy-MM-dd',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkDailyHospital",
				"derivedWeeklyNullValues sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     umask: 0777,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     dateFormat:'yyyy-MM-dd',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sinkWeeklyHospital"
			]
		}
	}
}