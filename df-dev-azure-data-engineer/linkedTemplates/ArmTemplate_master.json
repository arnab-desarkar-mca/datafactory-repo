{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "df-dev-azure-data-engineer"
		},
		"kv_azure_data_engineer_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://kv-dev-azuredataengineer.vault.azure.net/"
		},
		"ls_azure_adls_gen2_storage_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://sadevdataengineergen2.dfs.core.windows.net"
		},
		"ls_azure_blob_storage_properties_typeProperties_serviceEndpoint": {
			"type": "string",
			"defaultValue": "https://sadevdataengineerblob.blob.core.windows.net"
		},
		"ls_azure_sql_database_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "database-server-ipl.database.windows.net"
		},
		"ls_azure_sql_database_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "database-ipl"
		},
		"ls_azure_sql_database_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "azure-data-engineer"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "df-dev-azure-data-engineer_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"kv_azure_data_engineer_properties_typeProperties_baseUrl": {
						"value": "[parameters('kv_azure_data_engineer_properties_typeProperties_baseUrl')]"
					},
					"ls_azure_sql_database_properties_typeProperties_server": {
						"value": "[parameters('ls_azure_sql_database_properties_typeProperties_server')]"
					},
					"ls_azure_sql_database_properties_typeProperties_database": {
						"value": "[parameters('ls_azure_sql_database_properties_typeProperties_database')]"
					},
					"ls_azure_sql_database_properties_typeProperties_userName": {
						"value": "[parameters('ls_azure_sql_database_properties_typeProperties_userName')]"
					},
					"ls_azure_adls_gen2_storage_properties_typeProperties_url": {
						"value": "[parameters('ls_azure_adls_gen2_storage_properties_typeProperties_url')]"
					},
					"ls_azure_blob_storage_properties_typeProperties_serviceEndpoint": {
						"value": "[parameters('ls_azure_blob_storage_properties_typeProperties_serviceEndpoint')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}