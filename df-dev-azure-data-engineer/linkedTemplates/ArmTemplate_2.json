					{
						"name": "pipeline transform hospital admissions",
						"type": "ExecutePipeline",
						"dependsOn": [
							{
								"activity": "pipeline ingest ecdc data from http",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"pipeline": {
								"referenceName": "pl_transform_ecdc_hospital_data",
								"type": "PipelineReference"
							},
							"waitOnCompletion": true,
							"parameters": {}
						}
					},
					{
						"name": "pipeline transform non hive testing",
						"type": "ExecutePipeline",
						"dependsOn": [
							{
								"activity": "pipeline ingest ecdc data from http",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"pipeline": {
								"referenceName": "pl_transform_ecdc_testing",
								"type": "PipelineReference"
							},
							"waitOnCompletion": true,
							"parameters": {}
						}
					},
					{
						"name": "pipeline load sql cases and deaths",
						"type": "ExecutePipeline",
						"dependsOn": [
							{
								"activity": "pipeline transform cases and deaths",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"pipeline": {
								"referenceName": "pl_load_cases_and_deaths",
								"type": "PipelineReference"
							},
							"waitOnCompletion": true,
							"parameters": {}
						}
					},
					{
						"name": "pipeline load sql hospital admissions daily",
						"type": "ExecutePipeline",
						"dependsOn": [
							{
								"activity": "pipeline transform hospital admissions",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"secureInput": false
