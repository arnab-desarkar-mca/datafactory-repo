						"name": "data flow transform hospital data",
						"type": "ExecuteDataFlow",
						"dependsOn": [
							{
								"activity": "delete weekly folder",
								"dependencyConditions": [
									"Succeeded"
								]
							},
							{
								"activity": "delete daily folder",
								"dependencyConditions": [
									"Succeeded"
								]
							}
						],
						"policy": {
							"timeout": "0.00:10:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
