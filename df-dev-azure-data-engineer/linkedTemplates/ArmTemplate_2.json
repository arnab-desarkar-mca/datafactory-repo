									"sourceCountryLookupFile": {},
									"sourceDateLookup": {},
									"sinkDailyHospital": {},
									"sinkWeeklyHospital": {}
								}
							},
							"staging": {},
							"compute": {
								"coreCount": 8,
								"computeType": "General"
							},
							"traceLevel": "Fine"
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"folder": {
					"name": "covid19/transform"
				},
				"annotations": [],
				"lastPublishTime": "2026-05-25T10:31:10Z"
			},
			"dependsOn": []
		},
