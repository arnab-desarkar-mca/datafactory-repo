{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "df-dev-azure-data-engineer"
		},
		"trg_ingest_population_file_properties_typeProperties_scope": {
			"type": "string",
			"defaultValue": "/subscriptions/6315a390-3fa3-4426-b827-96a5426f1b57/resourceGroups/rg-dev-azure-data-engineer/providers/Microsoft.Storage/storageAccounts/sadevdataengineerblob"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
