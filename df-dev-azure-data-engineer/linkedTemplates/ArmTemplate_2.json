						"userProperties": [],
						"typeProperties": {
							"dataflow": {
								"referenceName": "df_transform_ecdc_hospital_admission",
								"type": "DataFlowReference",
								"parameters": {},
								"datasetParameters": {
									"sourceHospitalAdmission": {
										"p_fileName": "hospital_admissions.csv"
